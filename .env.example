# === 数据库 ===
DOCKER_IMAGE_PREFIX=docker.m.daocloud.io/
POSTGRES_USER=reflexlearn
POSTGRES_PASSWORD=reflexlearn
POSTGRES_DB=reflexlearn
DATABASE_URL=postgresql://reflexlearn:reflexlearn@127.0.0.1:15432/reflexlearn

# === Redis ===
REDIS_URL=redis://127.0.0.1:16379/0

# === Qdrant ===
QDRANT_URL=http://127.0.0.1:16333

# === Neo4j (graph profile) ===
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_PASSWORD=reflexlearn

# === LLM 供应商 API Keys（至少填一个） ===
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=

# === Kafka (bigdata profile) ===
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092

# === 功能开关 ===
ENABLE_REFLEXION=true
ENABLE_RERANK=true
ENABLE_GRAPH_RETRIEVAL=false
ENABLE_KAFKA=false

# === P0 安全底座 ===
APP_ENV=development
AUTH_ENABLED=true
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=7200
AUTH_ISSUER=reflexlearn
AUTH_AUDIENCE=reflexlearn-web
AUTH_DEMO_USERNAME=admin
AUTH_DEMO_PASSWORD=reflexlearn-admin
AUTH_DEMO_TENANT_ID=default
AUTH_DEMO_ROLE=admin

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
TRUSTED_HOSTS=127.0.0.1,localhost,testserver

MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,pptx,html,htm,md,txt
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/html,text/markdown,text/plain
